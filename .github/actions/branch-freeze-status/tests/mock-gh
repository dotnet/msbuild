#!/usr/bin/env bash
# Minimal mock of the GitHub CLI (`gh`) for the branch-freeze status tests.
# Implements ONLY the gh surface post-freeze-status.sh uses:
#   * `gh issue list ... --json ...`                 -> prints $MOCK_ISSUES (default [])
#   * `gh api -X POST .../statuses/<sha> -f k=v ...`  -> appends each k=v line to
#     $GH_STATUS_FILE (when set) so tests can assert on the posted commit status.
set -uo pipefail

cmd="${1:-}"; shift || true

case "$cmd" in
  issue)
    sub="${1:-}"; shift || true
    case "$sub" in
      list) printf '%s' "${MOCK_ISSUES:-[]}" ;;
      *) : ;;
    esac
    ;;
  api)
    endpoint=""
    keys=()
    vals=()
    while [ "$#" -gt 0 ]; do
      case "$1" in
        -f) keys+=("${2%%=*}"); vals+=("${2#*=}"); shift 2 ;;
        -X|--jq) shift 2 ;;
        -*) shift ;;
        *) endpoint="$1"; shift ;;
      esac
    done
    case "$endpoint" in
      */statuses/*)
        if [ -n "${GH_STATUS_FILE:-}" ]; then
          i=0
          while [ "$i" -lt "${#keys[@]}" ]; do
            printf '%s=%s\n' "${keys[$i]}" "${vals[$i]}" >> "$GH_STATUS_FILE"
            i=$((i + 1))
          done
        fi
        ;;
      *) echo "{}" ;;
    esac
    ;;
  *) : ;;
esac

exit 0
